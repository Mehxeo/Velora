{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "outDir": "dist-electron",
    "types": ["node", "electron"],
    "sourceMap": true,
    "declaration": false
  },
  "include": ["electron/**/*.ts"]
}
