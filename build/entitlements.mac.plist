<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Required for Chromium's JIT compiler (Electron / CEF) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Required for Electron's V8 engine to write to executable memory -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allow loading of dylibs not signed by Apple (native Node modules, etc.) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Microphone access – used by Live Audio Checker / Whisper transcription -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- Screen recording / capture – used by screen-context and live-helper shortcuts -->
    <key>com.apple.security.screen-capture</key>
    <true/>
  </dict>
</plist>
